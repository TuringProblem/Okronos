<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
	<statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{HH:mm:ss.SSS} %highlight(%level) %boldCyan(%thread) %boldGreen(%logger{36}:%line) %msg%n</pattern>
		</encoder>
	</appender>

  <appender name="STDOUT_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="STDOUT" />
  </appender>

	<appender name="SENTRY" class="io.sentry.logback.SentryAppender">
	</appender>

  <appender name="SENTRY_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="SENTRY" />
  </appender>

	<root level="info">
		<appender-ref ref="STDOUT_ASYNC" />
		<appender-ref ref="SENTRY_ASYNC" />
	</root>
	
</configuration>
